# Create a CSV file and write column headers
with open(log_file, mode="w", newline="") as file:
    writer = csv.writer(file)
    writer.writerow([
        "Timestamp",
        "Average Voltage (V)",
        "Minimum Voltage (V)",
        "Maximum Voltage (V)",
        "Peak-to-Peak Voltage (V)"
    ])

print(f"Logging voltage data to {log_file}")
print("Press CTRL+C to stop")

# Live waveform plot setup
plt.ion()  # turns on interactive plotting

time_axis = np.arange(num_samples) / sample_rate

figure, axis = plt.subplots(figsize=(10, 5))
line, = axis.plot(time_axis * 1000, np.zeros(num_samples))

axis.set_title("Live Analog Discovery Scope CH1 Waveform")
axis.set_xlabel("Time (ms)")
axis.set_ylabel("Voltage (V)")
axis.grid(True)
axis.set_ylim(-1.5, 1.5)

plt.show(block=False)

try:
    while True:
        # Start scope acquisition
        dwf.FDwfAnalogInConfigure(
            hdwf,
            c_bool(False),
            c_bool(True)
        )

        status = c_byte()

        # Wait until acquisition is complete
        while True:
            dwf.FDwfAnalogInStatus(
                hdwf,
                c_bool(True),
                byref(status)
            )

            if status.value == DwfStateDone.value:
                break

            time.sleep(0.01)

        # Read data
        samples = (c_double * num_samples)()

        dwf.FDwfAnalogInStatusData(
            hdwf,
            c_int(0),
            samples,
            c_int(num_samples)
        )

        data = np.array(samples)

        # Live waveform plot
        line.set_ydata(data)
        axis.set_title(f"Live Scope CH1 Waveform - {datetime.now().strftime('%H:%M:%S')}")
        figure.canvas.draw()
        figure.canvas.flush_events()
        plt.pause(0.05)

        average_voltage = np.mean(data)
        minimum_voltage = np.min(data)
        maximum_voltage = np.max(data)
        peak_to_peak_voltage = maximum_voltage - minimum_voltage
        timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")

        # Save data to CSV
        with open(log_file, mode="a", newline="") as file:
            writer = csv.writer(file)
            writer.writerow([
                timestamp,
                average_voltage,
                minimum_voltage,
                maximum_voltage,
                peak_to_peak_voltage
            ])

        print(
            f"{timestamp} | "
            f"Avg = {average_voltage:.4f} V | "
            f"Min = {minimum_voltage:.4f} V | "
            f"Max = {maximum_voltage:.4f} V | "
            f"Vpp = {peak_to_peak_voltage:.4f} V"
        )

        time.sleep(log_interval_seconds)

except KeyboardInterrupt:
    print("\nLogging stopped by user.")

finally:
    # Stop WaveGen
    dwf.FDwfAnalogOutConfigure(
        hdwf,
        c_int(0),
        c_bool(False)
    )

    dwf.FDwfDeviceClose(hdwf)

    print("Analog Discovery closed.")
